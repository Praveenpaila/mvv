# Security / Watchman backend
PORT=5005
MONGO_URL="mongodb://localhost:27017/"

# Body size limit for JSON requests (e.g., "1mb", "500kb")
JSON_LIMIT="1mb"

# CORS (required in production): comma-separated list of allowed origins
# Example: CORS_ORIGINS="https://watchman.example.com"
CORS_ORIGINS="http://localhost:5176"

