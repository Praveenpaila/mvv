# Backend configuration
PORT=3000
MONGO_URL="mongodb://localhost:27017/"
KEY="your_jwt_secret"

# Cloudinary
CLOUD_KEY="..."
CLOUD_SECRET="..."
CLOUD_NAME="..."

# SMTP (Email sending) - required for invoice/order update emails
# Use your SMTP provider or Gmail SMTP. Recommended: App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="MK Gold Coast <your_email@gmail.com>"

