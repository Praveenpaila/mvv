# Backend configuration
PORT=3000
MONGO_URL="mongodb://localhost:27017/"
KEY="your_jwt_secret"

# Cloudinary
CLOUD_KEY="..."
CLOUD_SECRET="..."
CLOUD_NAME="..."

# SMTP (Email sending) - required for invoice/order update emails
# Use your SMTP provider or Gmail SMTP. Recommended: App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="MVV <your_email@gmail.com>"

# SMS (Order placed / status update SMS)
# Set SMS_PROVIDER="fast2sms" for Fast2SMS style payload (default in code),
# SMS_PROVIDER="generic" for simple { to, message, from } payload,
# or SMS_PROVIDER="twilio" for Twilio API.
SMS_ENABLED=true
SMS_PROVIDER="fast2sms"
SMS_API_URL="https://www.fast2sms.com/dev/bulkV2"
SMS_API_KEY="your_sms_api_key"
SMS_FROM_NUMBER="6302853317"
SMS_SUPPORT_NUMBER="6302853317"
SMS_ROUTE="q"
SMS_SENDER_ID="MVV"
SMS_TIMEOUT_MS=10000

# Twilio (used when SMS_PROVIDER="twilio")
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+12345678900"

