## Mobile (Expo)
# For Expo, only EXPO_PUBLIC_* vars are exposed to the app.

# Recommended for production builds
# EXPO_PUBLIC_API_BASE_URL="https://yourdomain.com/api"
# EXPO_PUBLIC_SECURITY_API_URL="https://yourdomain.com"
# EXPO_PUBLIC_RAZORPAY_KEY_ID="rzp_live_xxx"

# Dev convenience: your PC LAN IP for physical devices
# EXPO_PUBLIC_DEVICE_IP="192.168.1.10"

